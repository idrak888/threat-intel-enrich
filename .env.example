# Threat Intel Enrichment Tool — Environment Variables
# Copy this file to .env and fill in your API keys
# Never commit .env to version control

# VirusTotal API key (free tier: 4 requests/min)
# Get yours at: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# AbuseIPDB API key (free tier: 1000 checks/day)
# Get yours at: https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# Cache TTL in seconds (default: 3600 = 1 hour)
ENRICHER_CACHE_TTL=3600
